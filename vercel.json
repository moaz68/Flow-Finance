{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.9.0" },
    "public/**/*.php": { "runtime": "vercel-php@0.9.0" },
    "index.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}