{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.6.1" },
    "public/**/*.php": { "runtime": "vercel-php@0.6.1" },
    "index.php": { "runtime": "vercel-php@0.6.1" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/public/(.*)", "destination": "/public/$1" },
    { "source": "/(.*)", "destination": "/index.php" }
  ]
}